er-bottom:1px solid #f1f5f9;font-size:14px;color:#1e293b\">{{$node[\"Parsear JSON\"].json.telefono}}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:12px 16px;border-bottom:1px solid #f1f5f9;font-size:12px;color:#94a3b8;text-transform:uppercase;font-weight:600\">Email</td>\n        <td style=\"padding:12px 16px;border-bottom:1px solid #f1f5f9;font-size:14px;color:#1e293b\"><a href=\"mailto:{{$node[\"Parsear JSON\"].json.email}}\" style=\"color:#2563eb;text-decoration:none\">{{$node[\"Parsear JSON\"].json.email}}</a></td>\n      </tr>\n      <tr>\n        <td style=\"padding:12px 16px;border-bottom:1px solid #f1f5f9;font-size:12px;color:#94a3b8;text-transform:uppercase;font-weight:600\">Categoría</td>\n        <td style=\"padding:12px 16px;border-bottom:1px solid #f1f5f9;font-size:14px;color:#1e293b\">{{$node[\"Parsear JSON\"].json.categoria_servicio}}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:12px 16px;font-size:12px;color:#94a3b8;text-transform:uppercase;font-weight:600\">Urgencia</td>\n        <td style=\"padding:12px 16px;font-size:14px;color:#1e293b\">{{$node[\"Parsear JSON\"].json.nivel_urgencia}}</td>\n      </tr>\n    </table>\n\n    <div style=\"background:#f8fafc;border-radius:12px;padding:16px 20px;margin-bottom:24px\">\n      <p style=\"margin:0 0 8px;font-size:12px;color:#94a3b8;font-weight:600;text-transform:uppercase\">💬 Motivo de la Consulta</p>\n      <p style=\"margin:0;font-size:14px;color:#334155;line-height:1.6\">{{$node[\"Parsear JSON\"].json.motivo_consulta}}</p>\n    </div>\n\n    <p style=\"font-size:12px;color:#94a3b8;text-align:center;margin:0\">Se ha enviado invitación de Google Calendar con enlace de Google Meet al cliente.</p>\n  </div>\n\n  <div style=\"background:#f8fafc;border-top:1px solid #e2e8f0;padding:16px 40px;text-align:center\">\n    <p style=\"margin:0;font-size:11px;color:#94a3b8\">R3 Consultores · Asesoría Contable, Legal y Financiera</p>\n    <p style=\"margin:4px 0 0;font-size:11px;color:#cbd5e