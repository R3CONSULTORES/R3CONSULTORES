    {
      "parameters": {
        "jsCode": "const parsed = JSON.parse($input.item.json.output);\n\n// ── Convertir fecha_propuesta a RFC3339 con offset Colombia (-05:00) ──\nconst raw = parsed.fecha_propuesta;\nlet d;\n\nif (raw.includes('-05:00')) {\n  d = new Date(raw);\n} else if (raw.includes('+00:00') || raw.endsWith('Z')) {\n  d = new Date(raw);\n} else {\n  d = new Date(raw + '-05:00');\n}\n\nfunction toColombiaRFC3339(date) {\n  const offset = -5 * 60 * 60 * 1000;\n  const col = new Date(date.getTime() + offset);\n  const y = col.getUTCFullYear();\n  const m = String(col.getUTCMonth() + 1).padStart(2, '0');\n  const dd = String(col.getUTCDate()).padStart(2, '0');\n  const hh = String(col.getUTCHours()).padStart(2, '0');\n  const mm = String(col.getUTCMinutes()).padStart(2, '0');\n  return `${y}-${m}-${dd}T${hh}:${mm}:00-05:00`;\n}\n\nconst startColombia = toColombiaRFC3339(d);\nconst endColombia = toColombiaRFC3339(new Date(d.getTime() + 2 * 60 * 60 * 1000));\n\n// Formatear fecha legible para los correos\nconst diasSemana = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];\nconst meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];\nconst colDate = new Date(d.getTime() + (-5 * 60 * 60 * 1000));\nconst fechaLegible = `${diasSemana[colDate.getUTCDay()]} ${colDate.getUTCDate()} de ${meses[colDate.getUTCMonth()]} de ${colDate.getUTCFullYear()}`;\nconst horaInicio = `${String(colDate.getUTCHours()).padStart(2,'0')}:${String(colDate.getUTCMinutes()).padStart(2,'0')}`;\nconst horaFin = `${String(colDate.getUTCHours() + 2).padStart(2,'0')}:${String(colDate.getUTCMinutes()).padStart(2,'0')}`;\n\nreturn {\n  nombre: parsed.nombre,\n  telefono: parsed.telefono,\n  email: parsed.email,\n  motivo_consulta: parsed.motivo_consulta,\n  fecha_propuesta: parsed.fecha_propuesta,\n  categoria_servicio: parsed.categoria_servicio || 'Consultoría General',\n  nivel_urgencia: parsed.nivel_urgencia || 'Normal',\n  start_colombia: startColombia,\n  end_colombia: endColombia,\n  fecha_legible: fechaLegible,\n  hora_inicio: horaInicio,\n  hora_fin: horaFin\n};"
      },
